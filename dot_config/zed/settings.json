// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "existing_window",
  "diff_view_style": "split",
  "inlay_hints": {
    "show_other_hints": true,
    "show_type_hints": true,
    "show_value_hints": true,
    "show_parameter_hints": false,
    "enabled": true
  },
  "collaboration_panel": {
    "button": false
  },
  "git_panel": {
    "show_count_badge": false,
    "file_icons": true,
    "tree_view": true,
    "dock": "left"
  },
  "project_panel": {
    "folder_icons": false,
    "default_width": 360.0,
    "indent_size": 14.0,
    "diagnostic_badges": true,
    "dock": "left"
  },
  "edit_predictions": {
    "provider": "copilot"
  },
  "buffer_line_height": "comfortable",
  "buffer_font_weight": 400.0,
  "tabs": {
    "show_diagnostics": "off",
    "file_icons": true,
    "git_status": true
  },
  "title_bar": {
    "show_menus": false
  },
  "cursor_blink": false,
  "agent": {
    "limit_content_width": true,
    "flexible": false,
    "default_width": 480.0,
    "dock": "left",
    "default_profile": "minimal",
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.5"
    },
    "model_parameters": []
  },
  "context_servers": {
    "mcp-server-context7": {
      "settings": {},

      "enabled": true
    }
  },
  "agent_servers": {
    "codex-acp": {
      "default_config_options": {
        "model": "gpt-5.4"
      },
      "favorite_config_option_values": {
        "model": ["gpt-5.4"]
      },
      "type": "registry"
    },
    "github-copilot-cli": {
      "type": "registry"
    }
  },
  "terminal": {
    "env": {
      "EDITOR": "\"zed -w\""
    },
    "max_scroll_history_lines": 2000
  },
  "base_keymap": "VSCode",
  "minimap": {
    "thumb": "always",
    "show": "never"
  },
  "autosave": "on_focus_change",
  "buffer_font_family": "FiraCode Nerd Font",
  "tab_size": 2,
  "vim_mode": false,
  "icon_theme": {
    "mode": "dark",
    "light": "Catppuccin Frappé",
    "dark": "JetBrains Icons Dark"
  },
  "ui_font_size": 13.0,
  "buffer_font_size": 10.0,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Snazzy Theme"
  },
  "diagnostics": {
    "inline": {
      "enabled": true
    }
  },
  "theme_overrides": {
    "Snazzy Theme": {
      "syntax": {
        "comment": {
          "color": "#7E8081FF"
        },
        "comment.doc": {
          "color": "#7E8081FF"
        }
      }
    }
  },
  "languages": {
    "CSS": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "GraphQL": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "Handlebars": {
