#!/usr/bin/env zsh

# gdn repo list でリポジトリ一覧と更新時刻を取得する
# 引数は無視（gdn.root の設定が使われる）
gdn repo list --column repo,updateAt,updateAtRelative --no-color \
  | while IFS=$'\t' read -r repo mtime relative_time; do
      [[ -z "$repo" ]] && continue
      printf "%s\t%s\t%-60s\t\033[2m%s\033[0m\n" "$mtime" "$repo" "$repo" "$relative_time"
    done | sort -t $'\t' -k1 -rn
