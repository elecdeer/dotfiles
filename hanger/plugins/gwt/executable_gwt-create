#!/usr/bin/env zsh
# worktreeを作成/解決し、パスをstdoutに出力する
# Usage: executable_gwt-create <worktree_name> <selected_path>
#   selected_path:
#     実際のパス              -> git wt <name> して返す
#     "__BASE__:"             -> current branchからgit wt <name>
#     "__BASE__:<branch>"     -> local <branch>からgit wt <name>
#     "__BASE__:origin/<b>"   -> local <b>をpullしてからgit wt <name>
#     "" (空)                 -> git wt <name> して探す
# exit 0: 成功（パスをstdout）, exit 1: 失敗

local worktree_name="$1"
local selected_path="$2"

_find_wt_path() {
  local branch="$1"
  git worktree list --porcelain | awk -v b="$branch" '
    /^worktree / { p = substr($0, 10) }
    /^branch / { if ($0 ~ "refs/heads/" b "$") print p }
  '
}

if [[ "$selected_path" == __BASE__:* ]]; then
  local base="${selected_path#__BASE__:}"
  if [[ "$base" == origin/* ]]; then
    # origin/<branch> -> local <branch>のworktreeをpullしてから新規branch作成
    local local_branch="${base#origin/}"
    git wt "$local_branch" >/dev/null 2>&1 || true  # worktreeがなければ作成 (既にある場合はエラーを無視)
    local base_path
    base_path=$(_find_wt_path "$local_branch")
    if [[ -z "$base_path" ]]; then
      echo "gwt: worktree not found for '$local_branch'" >&2
      exit 1
    fi
    (cd "$base_path" && git pull >/dev/null) || exit 1
    (cd "$base_path" && git wt "$worktree_name" >/dev/null) || exit 1
  elif [[ -n "$base" ]]; then
    git wt "$base" >/dev/null 2>&1 || true  # 既にある場合はエラーを無視
    git wt "$worktree_name" >/dev/null || exit 1
  else
    git wt "$worktree_name" >/dev/null || exit 1
  fi
  local result_path
  result_path=$(_find_wt_path "$worktree_name")
  [[ -z "$result_path" ]] && exit 1
  printf '%s\n' "$result_path"
elif [[ -n "$selected_path" ]]; then
  # 既存worktree: パスが既に判明しているのでそのまま返す（git wtは不要）
  printf '%s\n' "$selected_path"
else
  # path不明（クエリのみ確定など）
  git wt "$worktree_name" >/dev/null || exit 1
  local result_path
  result_path=$(_find_wt_path "$worktree_name")
  [[ -z "$result_path" ]] && exit 1
  printf '%s\n' "$result_path"
fi
