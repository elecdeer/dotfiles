#!/usr/bin/env zsh

# worktreeのリストを生成する
# 引数: [query] - クエリが指定された場合、末尾に "⊕ create: {query}" エントリを追加する

local query="${1:-}"

function _gwt_tracking_arrows() {
  local trackshort="$1"

  case "$trackshort" in
    '>')
      print -r -- $'\033[33m⇡\033[0m'
      ;;
    '<')
      print -r -- $'\033[31m⇣\033[0m'
      ;;
    '<>')
      print -r -- $'\033[33m⇡\033[0m\033[31m⇣\033[0m'
      ;;
    *)
      print -r -- ""
      ;;
  esac
}

typeset -A branch_arrows=()
typeset -A branch_commit_times=()
typeset -A branch_relative_times=()

while IFS=$'\t' read -r branch trackshort commit_time relative_time; do
  [[ -z "$branch" ]] && continue
  branch_arrows[$branch]="$(_gwt_tracking_arrows "$trackshort")"
  branch_commit_times[$branch]="${commit_time:-0}"
  branch_relative_times[$branch]="${relative_time:-0 seconds ago}"
done < <(git branch --format=$'%(refname:short)\t%(upstream:trackshort)\t%(committerdate:unix)\t%(committerdate:relative)')

git-wt | tail -n +2 | sed 's/^[ *]*//' | while IFS= read -r line; do
  wt_path=""
  branch=""
  hash="" 
  _rest=""
  commit_time=0
  relative_time=""
  arrows=""

  read -r wt_path branch hash _rest <<< "$line"

  [[ -z "$branch" || "$branch" == "(bare)" ]] && continue

  commit_time="${branch_commit_times[$branch]:-0}"
  relative_time="${branch_relative_times[$branch]:-0 seconds ago}"
  arrows="${branch_arrows[$branch]:-}"

  printf "%s\t%s\t%s\t\033[34m%-45s\033[0m\t\033[90m%-8s\033[0m\t\033[2m%s\033[0m\t%s\n" \
    "$commit_time" "$branch" "$wt_path" "$branch" "$hash" "$relative_time" "$arrows"
done | sort -t $'\t' -k1 -rn | cut -f2-

# クエリがある場合、分岐元ごとのcreateエントリを末尾に追加
# f2に "__BASE__:{base_branch}" を埋め込み、gwt側で分岐元を判別する
if [[ -n "$query" ]]; then
  local default_branch current_branch
  default_branch=$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | cut -d/ -f2-)
  default_branch="${default_branch:-main}"
  current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)

  # originにブランチが既にある場合はcheckoutエントリのみ表示
  if git show-ref --verify --quiet "refs/remotes/origin/$query"; then
    printf "%s\t__BASE__:\t\033[32m* checkout from origin/%s\033[0m\t\033[2m%s\033[0m\t\t\n" \
      "$query" "$query" "$query"
    return
  fi

  # local mainとorigin/mainに差分がある場合はorigin/mainの選択肢も追加する
  local local_hash remote_hash origin_entry=""
  local_hash=$(git rev-parse "refs/heads/$default_branch" 2>/dev/null)
  remote_hash=$(git rev-parse "refs/remotes/origin/$default_branch" 2>/dev/null)
  if [[ -n "$remote_hash" && "$local_hash" != "$remote_hash" ]]; then
    origin_entry="origin/$default_branch"
  fi

  if [[ "$default_branch" != "$current_branch" ]]; then
    printf "%s\t__BASE__:%s\t\033[32m* create branch from %s\033[0m\t\033[2m%s\033[0m\t\t\n" \
      "$query" "$default_branch" "$default_branch" "$query"
    if [[ -n "$origin_entry" ]]; then
      printf "%s\t__BASE__:%s\t\033[32m* create branch from %s\033[0m\t\033[2m%s\033[0m\t\t\n" \
        "$query" "$origin_entry" "$origin_entry" "$query"
    fi
    printf "%s\t__BASE__:\t\033[32m* create branch from %s\033[0m\t\033[2m%s\033[0m\t\t\n" \
      "$query" "$current_branch" "$query"
  else
    if [[ -n "$origin_entry" ]]; then
      printf "%s\t__BASE__:%s\t\033[32m* create branch from %s\033[0m\t\033[2m%s\033[0m\t\t\n" \
        "$query" "$origin_entry" "$origin_entry" "$query"
    fi
    printf "%s\t__BASE__:\t\033[32m* create branch\033[0m\t\033[2m%s\033[0m\t\t\n" \
      "$query" "$query"
  fi
fi
